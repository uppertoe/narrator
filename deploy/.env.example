# Narrator app configuration.
# Copy to apps/narrator/.env in your server repo and fill in what you need. Never
# commit the real .env — the deploy helper sets it to mode 600 on the server.
# DOMAIN is inherited from the server repo's root .env (app is at narrator.<DOMAIN>).

# --- Claude extraction (optional) ---
# If unset, Narrator uses its built-in deterministic parser. Set this to have
# Claude parse utterances (better on shorthand / mishears) — but it adds a
# ~1.5-3.5s API round-trip per utterance, which hurts on a slow box.
# ANTHROPIC_API_KEY=sk-ant-...
# NARRATOR_MODEL=claude-haiku-4-5      # or claude-sonnet-4-6 / claude-opus-4-8
# NARRATOR_USE_LLM=0                   # force-disable LLM extraction (keep the key for later)

# --- Speech-to-text (optional) ---
# base.en is baked into the image. small.en is more accurate in noise but is NOT
# baked — it would download on first use, which fails on the read-only filesystem
# unless you also provide a writable model cache. Stick with base.en unless you
# rebuild the image with small.en baked in.
# NARRATOR_WHISPER_MODEL=base.en
# NARRATOR_WHISPER_BEAM=5
